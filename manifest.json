{
  "manifest_version": 3,
  "name": "Register",
  "version": "0.1.0",
  "description": "Save writing you admire. Measure what it actually does. Compare your drafts against it.",
  "permissions": ["storage", "unlimitedStorage", "scripting", "activeTab", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_title": "Register" },
  "icons": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    { "resources": ["dashboard.html"], "matches": ["<all_urls>"] }
  ]
}
